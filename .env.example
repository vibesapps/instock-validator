# Kopyala: cp .env.example .env

# Kaç dakikada bir scrape yapılsın
SCRAPE_INTERVAL_MINUTES=30

# Kaç saatte bir rapor üretilsin
REPORT_INTERVAL_HOURS=24

# İstekler arasındaki minimum/maksimum bekleme (saniye)
# Bu aralık rastgele seçilir — çok düşürme, ban riskini artırır
MIN_DELAY_SECONDS=8
MAX_DELAY_SECONDS=20

# Proxy listesi (virgülle ayrılmış). Ban yenince buraya ekle:
# PROXY_LIST=http://user:pass@proxy1.example.com:8080,http://user:pass@proxy2.example.com:8080
PROXY_LIST=
